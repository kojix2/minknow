    # Service is the generated abstract base class for server implementations.
    # Subclass it and implement each RPC method, then register with GRPC::Server#handle.
    abstract class Service < GRPC::Service
      def service_full_name : String
        FULL_NAME
      end

      # Override this hook to swap marshaller implementations.
      protected def marshaller_for(type : T.class) : GRPC::Marshaller(T) forall T
        GRPC::ProtoMarshaller(T).new
