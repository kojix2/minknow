          {res_marshaller.encode(resp), GRPC::Status.ok}
        when "get_current_protocol_run"
          req_marshaller = marshaller_for(GetCurrentProtocolRunRequest)
          res_marshaller = marshaller_for(ProtocolRunInfo)
